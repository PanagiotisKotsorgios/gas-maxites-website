# Copy to .env for local Docker dev, or set as environment variables
# in Coolify's application settings.

# ---- Database ----
DB_HOST=db
DB_NAME=gas_maxites
DB_USER=maxites
DB_PASS=change-this-strong-password

# ---- Site ----
SITE_NAME=Γ.Α.Σ. Μαχητές Μεσολογγίου
SITE_NAME_SHORT=ΜΑΧΗΤΕΣ
